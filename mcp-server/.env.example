PORT=3001
HOST=0.0.0.0
TRANSPORT=http
WS_PORT=3002
LOG_LEVEL=info
NODE_ENV=development

# Security
MAX_COMMAND_TIMEOUT_MS=30000
MAX_OUTPUT_BYTES=512000
RATE_LIMIT_RPM=120

# Shell
DEFAULT_CWD=/tmp/nexus-sandbox
MAX_SHELL_SESSIONS=10
SHELL_SESSION_TIMEOUT_MS=300000

# Token cost estimates (USD per 1k tokens, defaults to Claude Sonnet 4.x)
INPUT_COST_PER_1K_USD=0.003
OUTPUT_COST_PER_1K_USD=0.015
BURN_ALERT_THRESHOLD_PER_HOUR=1.0

# Telemetry
SNAPSHOT_INTERVAL_MS=5000
TELEMETRY_RETENTION_MS=3600000
